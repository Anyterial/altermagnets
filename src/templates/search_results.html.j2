{% if not result.dataset_available %}
<div class="notice-block">
  <p>{{ site_stats.notice }}</p>
</div>
{% else %}
<section class="result-summary">
  <p>{{ result.summary }}</p>
  {% if result.active_filters %}
  <div class="filter-pill-row" aria-label="Active filters">
    {% for item in result.active_filters %}
    <span class="filter-pill"><strong>{{ item.label }}</strong> {{ item.value }}</span>
    {% endfor %}
  </div>
  {% endif %}
</section>

{% if result["items"] and result["items"]|length > 0 %}
<div class="table-wrap search-table-wrap">
  <table class="results-table search-results-table" aria-label="Search results table">
    <thead>
      <tr>
        <th class="col-material">
          Material
        </th>
        <th class="col-magndata">MAGNDATA IDs
          <span tabindex="0" class="info-dot" role="button" aria-label="More information">
            i
            <span class="info-bubble" role="tooltip">
              <span class="info-bubble-paragraph">
                A screened entry may correspond to one or more entries in the MAGNDATA database.
              </span>
            </span>
          </span>
        </th>
        <th class="col-collinearity">
          Collinearity
          <span tabindex="0" class="info-dot" role="button" aria-label="More information">
            i
            <span class="info-bubble" role="tooltip">
              <span class="info-bubble-paragraph">
                Whether the magnetic configuration was collinear in MAGNDATA or constructed from a noncollinear entry.
              </span>
            </span>
          </span>
        </th>
        <th class="col-spacegroup">Space group</th>
        <th class="col-maxss">
          $\Delta E^{\mathrm{max}}_{\mathrm{split}}$
          <span tabindex="0" class="info-dot" role="button" aria-label="More information">
            i
            <span class="info-bubble" role="tooltip">
              <span class="info-bubble-paragraph">
                Largest spin splitting within ±3 eV of the Fermi level in the high-throughput calculation.
              </span>
            </span>
          </span>
        </th>
        <th class="col-avgss">$\Delta E^{\mathrm{avg}}_{\mathrm{split}}$
          <span tabindex="0" class="info-dot" role="button" aria-label="More information">
            i
            <span class="info-bubble" role="tooltip">
              <span class="info-bubble-paragraph">
                Brillouin-zone average of the largest spin splitting at each k-point within the same energy window.
              </span>
            </span>
          </span>
        </th>
        <th class="col-fdelta">FΔ
          <span tabindex="0" class="info-dot" role="button" aria-label="More information">
            i
            <span class="info-bubble" role="tooltip">
              <span class="info-bubble-paragraph">
              Fraction of the sampled Brillouin zone and near-Fermi bands with appreciable spin splitting.
              </span>
            </span>
          </span>
        </th>
        <th class="col-gap">KS Gap
          <span tabindex="0" class="info-dot" role="button" aria-label="More information">
            i
            <span class="info-bubble" role="tooltip">
              <span class="info-bubble-paragraph">
              The band gap from Kohn-Sham DFT.
              </span>
            </span>
          </span>
        </th>
        <th class="col-abundance">
          Min abundance
          <span tabindex="0" class="info-dot" role="button" aria-label="More information">
            i
            <span class="info-bubble" role="tooltip">
              <span class="info-bubble-paragraph">
                Minimum crustal abundance among the constituent elements, reported in ppm as a simple scarcity proxy.
              </span>
            </span>
          </span>
        </th>
      </tr>
    </thead>
    <tbody>
      {% for item in result["items"] %}
      <tr class="result-row" data-row-url="{{ page.relbaseurl }}/material?id={{ item.material_id }}" tabindex="0">
        <td class="col-material">
          <div class="cell-title">{{ item.material_label if item.material_label else item.material }}</div>
          <div class="cell-meta cell-meta-id"><span class="id-mono">{{ item.material_id }}</span></div>
        </td>
        <td class="col-magndata">{{ item.magndata_ids | join(", ") }}</td>
        <td class="col-collinearity">{{ item.classification_label }}</td>
        <td class="col-spacegroup">{{ item.space_group }}</td>
        <td class="col-maxss">{{ item.max_ss_display }} eV</td>
        <td class="col-avgss">{{ item.avg_ss_display }} eV</td>
        <td class="col-fdelta">{{ item.fdelta_display }}</td>
        <td class="col-gap">{{ item.bandgap_display }} eV</td>
        <td class="col-abundance">{{ item.abundance_display }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% else %}
<p class="empty">No matches found for the current filter set.</p>
{% endif %}
{% endif %}
