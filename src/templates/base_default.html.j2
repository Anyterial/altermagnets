<!doctype html>
<html lang="en" data-theme="twilight">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title }} | Altermagnets Database</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=Instrument+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex/dist/katex.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="{{ page.relbaseurl }}/styles.css" />
  </head>
  <body>
    <div class="app-shell">
      <header class="topbar">
        <div class="brand-row">
          <a href="https://www.anyterial.se">
            <img
              src="https://www.anyterial.se/img/anyterial_logo_color.svg"
              alt="Anyterial logo"
              class="brand-logo"
            />
          </a>
          <div class="brand-copy">
            <h1><a style="all: unset; cursor:pointer;" href="/">Altermagnets Database</a></h1>
            <p>High-throughput computational screening for altermagnetic materials</p>
          </div>
        </div>
        <div class="topbar-actions">
          <div class="theme-switch" role="group" aria-label="Theme">
            <button type="button" class="theme-btn" data-theme-option="dark" aria-label="Use dark theme" title="Dark mode">
              <img class="theme-icon" src="{{ page.relbaseurl }}/icons/Hicon_Pack_1/moon.svg" alt="" aria-hidden="true" />
            </button>
            <button type="button" class="theme-btn" data-theme-option="twilight" aria-label="Use twilight theme" title="Twilight mode">
              <img class="theme-icon" src="{{ page.relbaseurl }}/icons/Hicon_Pack_1/sun-half.svg" alt="" aria-hidden="true" />
            </button>
            <button type="button" class="theme-btn" data-theme-option="light" aria-label="Use light theme" title="Light mode">
              <img class="theme-icon" src="{{ page.relbaseurl }}/icons/Hicon_Pack_1/sun.svg" alt="" aria-hidden="true" />
            </button>
          </div>
        </div>
      </header>

      {% set current_page = page.relurl if page.relurl else 'index' %}
      {% if current_page == 'material' %}
      {% set current_section = 'search' %}
      {% elif current_page == 'index' %}
      {% set current_section = 'home' %}
      {% else %}
      {% set current_section = current_page %}
      {% endif %}

      <nav class="page-tabs" aria-label="Primary">
        <a href="{{ page.relbaseurl }}/index" class="page-tab{% if current_section == 'home' %} is-active{% endif %}">Home</a>
        <a href="{{ page.relbaseurl }}/search" class="page-tab{% if current_section == 'search' %} is-active{% endif %}">Search</a>
        <a href="{{ page.relbaseurl }}/highlights" class="page-tab{% if current_section == 'highlights' %} is-active{% endif %}">Highlights</a>
        <a href="{{ page.relbaseurl }}/about" class="page-tab{% if current_section == 'about' %} is-active{% endif %}">About</a>
        <a href="{{ page.relbaseurl }}/how-to-cite" class="page-tab{% if current_section == 'how-to-cite' %} is-active{% endif %}">How to cite</a>
      </nav>

      <div class="layout-grid">
        <aside class="sidebar panel">
          <section class="search-card">
            <div class="search-card-header">
              <h2>Search altermagnets</h2>
              <p>
                Filter the screened altermagnets by chemistry, electronic character, and collinearity class.
              </p>
            </div>

            <form method="get" action="{{ page.relbaseurl }}/search" class="search-form">
              <div class="form-section">
                <label for="global-search" class="field-label">
                  Text query
                  <span tabindex="0" class="info-dot" role="button" aria-label="More information">
                    i
                    <span class="info-bubble" role="tooltip">
                      <span class="info-bubble-paragraph">
                        Matches material formulas, MAGNDATA identifiers, space-group strings, and symmetry labels.
                      </span>
                    </span>
                  </span>
                </label>
                <input
                  id="global-search"
                  name="q"
                  type="text"
                  value="{{ query.q if query.q else '' }}"
                  placeholder="e.g. CrSb, 0.528, Pnma"
                />
              </div>

              <div class="form-section">
                <label for="elements" class="field-label">
                  Elements
                  <span tabindex="0" class="info-dot" role="button" aria-label="More information">
                    i
                    <span class="info-bubble" role="tooltip">
                      <span class="info-bubble-paragraph">
                        Require all listed element symbols to be present in the chemical formula.
                      </span>
                    </span>
                  </span>
                </label>
                <input
                  id="elements"
                  name="elements"
                  type="text"
                  value="{{ query.elements if query.elements else '' }}"
                  placeholder="e.g. Mn O"
                />
              </div>

              <div class="form-grid">
                <div class="form-section">
                  <label for="classification" class="field-label">
                    Collinearity
                    <span tabindex="0" class="info-dot" role="button" aria-label="More information">
                      i
                      <span class="info-bubble" role="tooltip">
                        <span class="info-bubble-paragraph">
                          Distinguishes naturally collinear MAGNDATA entries from entries that only appear after collinearizing a noncollinear parent, or from a combination of both.
                        </span>
                      </span>
                    </span>
                  </label>
                  <select id="classification" name="classification">
                    {% for option in search_options.classifications %}
                    <option value="{{ option.value }}" {% if query.classification == option.value %}selected{% endif %}>{{ option.label }}</option>
                    {% endfor %}
                  </select>
                </div>

                <div class="form-section">
                  <label for="electronic_type" class="field-label">
                    Electronic type
                    <span tabindex="0" class="info-dot" role="button" aria-label="More information">
                      i
                      <span class="info-bubble" role="tooltip">
                        <span class="info-bubble-paragraph">
                          Derived from the reported band gap in the screening table. Zero gap is treated as metallic.
                        </span>
                      </span>
                    </span>
                  </label>
                  <select id="electronic_type" name="electronic_type">
                    {% for option in search_options.electronic_types %}
                    <option value="{{ option.value }}" {% if query.electronic_type == option.value %}selected{% endif %}>{{ option.label }}</option>
                    {% endfor %}
                  </select>
                </div>
              </div>

              <div class="form-grid">
                <div class="form-section">
                  <label for="magnetic_phase" class="field-label">
                    Phase
                    <span tabindex="0" class="info-dot" role="button" aria-label="More information">
                      i
                      <span class="info-bubble" role="tooltip">
                        <span class="info-bubble-paragraph">
                          Symmetry-screening phase label from the MAGNDATA summary tables: AM for altermagnet and FiM for ferrimagnet.
                        </span>
                      </span>
                    </span>
                  </label>
                  <select id="magnetic_phase" name="magnetic_phase">
                    {% for option in search_options.magnetic_phases %}
                    <option value="{{ option.value }}" {% if query.magnetic_phase == option.value %}selected{% endif %}>{{ option.label }}</option>
                    {% endfor %}
                  </select>
                </div>

                <div class="form-section">
                  <label for="wave_class" class="field-label">
                    Wave class
                    <span tabindex="0" class="info-dot" role="button" aria-label="More information">
                      i
                      <span class="info-bubble" role="tooltip">
                        <span class="info-bubble-paragraph">
                          Symmetry wave-class shorthand derived from the parent and halving-subgroup Laue classes used in the altermagnetism analysis.
                        </span>
                      </span>
                    </span>
                  </label>
                  <select id="wave_class" name="wave_class">
                    {% for option in search_options.wave_classes %}
                    <option value="{{ option.value }}" {% if query.wave_class == option.value %}selected{% endif %}>{{ option.label }}</option>
                    {% endfor %}
                  </select>
                </div>
              </div>

              <div class="form-section">
                <label for="space-group" class="field-label">
                  Space group
                  <span tabindex="0" class="info-dot" role="button" aria-label="More information">
                    i
                    <span class="info-bubble" role="tooltip">
                      <span class="info-bubble-paragraph">
                        Matches the crystallographic space-group label reported for the screened material row.
                      </span>
                    </span>
                  </span>
                </label>
                <input
                  id="space-group"
                  name="space_group"
                  type="text"
                  value="{{ query.space_group if query.space_group else '' }}"
                  placeholder="e.g. P6_3/mmc"
                />
              </div>

              <div class="form-section">
                <h3>Metric thresholds</h3>
                <p class="section-note">Tighten the search using the reported spin splitting, gap, and elemental abundance values.</p>
                <div class="form-grid metric-input-grid">
                  <div>
                    <label for="min-max-ss" class="field-label">
                      Max SS ≥
                      <span tabindex="0" class="info-dot" role="button" aria-label="More information">
                        i
                        <span class="info-bubble" role="tooltip">
                          <span class="info-bubble-paragraph">
                            Largest spin splitting found within ±3 eV of the Fermi level in the screening calculation.
                          </span>
                        </span>
                      </span>
                    </label>
                    <div class="input-with-unit">
                      <input id="min-max-ss" name="min_max_ss" type="number" step="0.001" min="0" value="{{ query.min_max_ss if query.min_max_ss else '' }}" />
                      <span>eV</span>
                    </div>
                  </div>
                  <div>
                    <label for="min-avg-ss" class="field-label">
                      Avg SS ≥
                      <span tabindex="0" class="info-dot" role="button" aria-label="More information">
                        i
                        <span class="info-bubble" role="tooltip">
                          <span class="info-bubble-paragraph">
                            Brillouin-zone average of the largest spin splitting at each k-point within the same energy window.
                          </span>
                        </span>
                      </span>
                    </label>
                    <div class="input-with-unit">
                      <input id="min-avg-ss" name="min_avg_ss" type="number" step="0.001" min="0" value="{{ query.min_avg_ss if query.min_avg_ss else '' }}" />
                      <span>eV</span>
                    </div>
                  </div>
                  <div>
                    <label for="min-fdelta-pct" class="field-label">
                      FΔ ≥
                      <span tabindex="0" class="info-dot" role="button" aria-label="More information">
                        i
                        <span class="info-bubble" role="tooltip">
                          <span class="info-bubble-paragraph">
                            Fraction of the sampled Brillouin zone and near-Fermi bands with appreciable spin splitting.
                          </span>
                        </span>
                      </span>
                    </label>
                    <div class="input-with-unit">
                      <input id="min-fdelta-pct" name="min_fdelta_pct" type="number" step="0.1" min="0" value="{{ query.min_fdelta_pct if query.min_fdelta_pct else '' }}" />
                      <span>%</span>
                    </div>
                  </div>
                  <div>
                    <label for="min-bandgap" class="field-label">
                      Band gap ≥
                      <span tabindex="0" class="info-dot" role="button" aria-label="More information">
                        i
                        <span class="info-bubble" role="tooltip">
                          <span class="info-bubble-paragraph">
                            Lower bound on the calculated band gap. Use together with the upper bound to isolate semiconducting windows.
                          </span>
                        </span>
                      </span>
                    </label>
                    <div class="input-with-unit">
                      <input id="min-bandgap" name="min_bandgap" type="number" step="0.001" min="0" value="{{ query.min_bandgap if query.min_bandgap else '' }}" />
                      <span>eV</span>
                    </div>
                  </div>
                  <div>
                    <label for="max-bandgap" class="field-label">Band gap ≤</label>
                    <div class="input-with-unit">
                      <input id="max-bandgap" name="max_bandgap" type="number" step="0.001" min="0" value="{{ query.max_bandgap if query.max_bandgap else '' }}" />
                      <span>eV</span>
                    </div>
                  </div>
                  <div>
                    <label for="min-abundance" class="field-label">
                      Min abundance ≥
                      <span tabindex="0" class="info-dot" role="button" aria-label="More information">
                        i
                        <span class="info-bubble" role="tooltip">
                          <span class="info-bubble-paragraph">
                            Lower bound on the least abundant constituent element, reported in parts per million in the Earth’s crust.
                          </span>
                        </span>
                      </span>
                    </label>
                    <div class="input-with-unit">
                      <input id="min-abundance" name="min_abundance_ppm" type="number" step="0.001" min="0" value="{{ query.min_abundance_ppm if query.min_abundance_ppm else '' }}" />
                      <span>ppm</span>
                    </div>
                  </div>
                </div>
              </div>

              <div class="form-section">
                <label for="sort" class="field-label">Sort results</label>
                <select id="sort" name="sort">
                  {% for option in search_options.sorts %}
                  <option value="{{ option.value }}" {% if (query.sort if query.sort else 'screening_rank') == option.value %}selected{% endif %}>{{ option.label }}</option>
                  {% endfor %}
                </select>
              </div>

              <div class="button-row">
                <button type="submit">Run search</button>
                <a class="secondary-button" href="{{ page.relbaseurl }}/search">Clear filters</a>
              </div>
            </form>
          </section>
        </aside>

        <main class="content panel">
          {{ content }}
        </main>
      </div>

      <footer class="app-footer panel">
            <div style="display: block;  max-width: fit-content; margin-left: auto; margin-right: auto;">
              <small style="display: block; font-size: 0.8em; color: #777777;"><span style="white-space:nowrap;">&copy; 2026 - <a href="/about">Altermagnets Database authors</a></span> &nbsp;&nbsp;&nbsp;&nbsp;-&nbsp;&nbsp;&nbsp;&nbsp; <span style="white-space:nowrap;">This website does not use cookies.</span> &nbsp;&nbsp;&nbsp;&nbsp;-&nbsp;&nbsp;&nbsp;&nbsp; <span style="white-space:nowrap;"><a href="/about#legal" style="color: #777777; text-decoration: underline;">Legal and licensing info</a></span>&nbsp;&nbsp;&nbsp;&nbsp;-&nbsp;&nbsp;&nbsp;&nbsp;
                <span style="white-space:nowrap;">
                  <a href="https://github.com/orgs/anyterial/discussions/categories/amdb"><svg style="fill: #777777;" width="1.5em" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512"><!--!Font Awesome Free 6.5.2 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2024 Fonticons, Inc. Icon modified by Rickard Armiento--><path d="m64 32c-35.3 0-64 28.7-64 64v320c0 35.3 28.7 64 64 64h320c35.3 0 64-28.7 64-64v-32.9c0.27-1.84 0.439-3.71 0.439-5.61v-248c0-1.9-0.169-3.77-0.439-5.61v-28.2c0-35.3-28.7-64-64-64h-320zm160 97.8c42.4 0 82.2 12.8 112 36 29.9 23.2 47.9 54 47.9 86.8 0 67.6-72.7 123-160 123-26.6 0-52.7-5.19-75.8-14.9l-84.1 17.1 22.5-63.6c-13.9-18.6-21.2-39.7-21.2-61.4 0.1-67.6 71.2-123 159-123z"/></svg></a>
                  &nbsp;<a href="https://pages.anyterial.se/subscribe"><svg style="fill: #777777;" width="1.5em" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512"><!--!Font Awesome Free 6.5.2 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2024 Fonticons, Inc.--><path d="M64 32C28.7 32 0 60.7 0 96V416c0 35.3 28.7 64 64 64H384c35.3 0 64-28.7 64-64V96c0-35.3-28.7-64-64-64H64zM218 271.7L64.2 172.4C66 156.4 79.5 144 96 144H352c16.5 0 30 12.4 31.8 28.4L230 271.7c-1.8 1.2-3.9 1.8-6 1.8s-4.2-.6-6-1.8zm29.4 26.9L384 210.4V336c0 17.7-14.3 32-32 32H96c-17.7 0-32-14.3-32-32V210.4l136.6 88.2c7 4.5 15.1 6.9 23.4 6.9s16.4-2.4 23.4-6.9z"/></svg></a>
                  &nbsp;<a href="https://github.com/anyterial/discussions/discussions/categories/announcements.atom"><svg style="fill: #777777;" width="1.5em"  xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512"><!--!Font Awesome Free 6.5.2 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2024 Fonticons, Inc.--><path d="M64 32C28.7 32 0 60.7 0 96V416c0 35.3 28.7 64 64 64H384c35.3 0 64-28.7 64-64V96c0-35.3-28.7-64-64-64H64zM96 136c0-13.3 10.7-24 24-24c137 0 248 111 248 248c0 13.3-10.7 24-24 24s-24-10.7-24-24c0-110.5-89.5-200-200-200c-13.3 0-24-10.7-24-24zm0 96c0-13.3 10.7-24 24-24c83.9 0 152 68.1 152 152c0 13.3-10.7 24-24 24s-24-10.7-24-24c0-57.4-46.6-104-104-104c-13.3 0-24-10.7-24-24zm0 120a32 32 0 1 1 64 0 32 32 0 1 1 -64 0z"/></svg></a>
                </span>
              </small>
            </div>
      </footer>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/katex/dist/katex.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/katex/dist/contrib/auto-render.min.js" crossorigin="anonymous"></script>
    <script src="{{ page.relbaseurl }}/app.js"></script>
  </body>
</html>
