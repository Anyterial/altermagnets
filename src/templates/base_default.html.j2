<!doctype html>
<html lang="en" data-theme="twilight">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title }} | Anyterial altermagnets</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=Instrument+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="{{ page.relbaseurl }}/styles.css" />
  </head>
  <body>
    <div class="app-shell">
      <header class="topbar panel">
        <div class="topbar-main">
          <div class="brand-row">
            <img
              src="https://www.anyterial.se/img/anyterial_logo_color.svg"
              alt="Anyterial logo"
              class="brand-logo"
            />
            <h1>Anyterial altermagnets</h1>
          </div>
          <nav class="top-nav" aria-label="Primary">
            <a href="{{ page.relbaseurl }}/index" class="top-nav-link">Welcome</a>
            <a href="{{ page.relbaseurl }}/search" class="top-nav-link">Search</a>
            <a href="{{ page.relbaseurl }}/about" class="top-nav-link">About</a>
          </nav>
        </div>
        <div class="topbar-actions">
          <div class="theme-switch" role="group" aria-label="Theme">
            <button type="button" class="theme-btn" data-theme-option="dark" aria-label="Use dark theme" title="Dark mode">
              <img class="theme-icon" src="{{ page.relbaseurl }}/icons/Hicon_Pack_1/moon.svg" alt="" aria-hidden="true" />
            </button>
            <button type="button" class="theme-btn" data-theme-option="twilight" aria-label="Use twilight theme" title="Twilight mode">
              <img class="theme-icon" src="{{ page.relbaseurl }}/icons/Hicon_Pack_1/sun-half.svg" alt="" aria-hidden="true" />
            </button>
            <button type="button" class="theme-btn" data-theme-option="light" aria-label="Use light theme" title="Light mode">
              <img class="theme-icon" src="{{ page.relbaseurl }}/icons/Hicon_Pack_1/sun.svg" alt="" aria-hidden="true" />
            </button>
          </div>
        </div>
      </header>

      <div class="layout-grid">
        <aside class="sidebar panel">
          <section class="search-card">
            <h2>Search Materials</h2>
            <p>Filter by formula, element symbols, space group, or magnetic order.</p>
            <form method="get" action="{{ page.relbaseurl }}/search" class="search-form">
              <label for="global-search">Query</label>
              <input
                id="global-search"
                name="q"
                type="text"
                value="{{ query.q if query.q else '' }}"
                placeholder="e.g. Mn O, Fe, P4/nmm"
              />
              <button type="submit">Run search</button>
            </form>
          </section>
        </aside>

        <main class="content panel">
          {{ content }}
        </main>
      </div>

      <footer class="app-footer panel">
        <p>
          This website does not use cookies. The data is provided under
          <a href="https://creativecommons.org/licenses/by/4.0/">CC-BY 4.0</a>.
          Icons provided by <a href="https://hicon.me/">hicon by cosimo scarpa</a>.
        </p>
        <a class="cc-badge-link" href="https://creativecommons.org/licenses/by/4.0/" aria-label="Creative Commons BY 4.0">
          <img
            class="cc-badge"
            src="https://licensebuttons.net/l/by/4.0/88x31.png"
            alt="Creative Commons Attribution 4.0 License"
          />
        </a>
      </footer>
    </div>

    <script src="{{ page.relbaseurl }}/app.js"></script>
  </body>
</html>
