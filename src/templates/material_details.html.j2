{% if result %}
<section class="material-card">
  <header>
    <h2>{{ result.name }}</h2>
    <p class="meta-line">{{ result.formula }} | {{ result.spacegroup }} | {{ result.order }}</p>
  </header>

  <div class="detail-sections">
    <section class="detail-subcard">
      <h3>Identity</h3>
      <dl class="details-grid">
        <div>
          <dt>ID</dt>
          <dd>{{ result.id }}</dd>
        </div>
        <div>
          <dt>Elements</dt>
          <dd>{{ result.elements | join(", ") }}</dd>
        </div>
        <div class="details-wide">
          <dt>Notes</dt>
          <dd>{{ result.notes }}</dd>
        </div>
      </dl>
    </section>

    <section class="detail-subcard">
      <h3>Properties</h3>
      <dl class="details-grid properties-grid">
        <div>
          <dt>Néel temperature (mock)</dt>
          <dd>{{ result.neel_temperature }}</dd>
        </div>
      </dl>
    </section>
  </div>
</section>
{% else %}
<p class="empty">Material id not found.</p>
{% endif %}
