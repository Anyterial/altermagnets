<article class="page-block">
  <h2>{{ title }}</h2>
  {{ content }}
  <section class="highlight-grid">
    <div class="highlight-card">
      <h3>Server-side search</h3>
      <p>Queries are evaluated by httk-web functions in <code>src/functions/</code>.</p>
    </div>
    <div class="highlight-card">
      <h3>Refinable workflow</h3>
      <p>Keep refining the query from the left pane while browsing results and details.</p>
    </div>
    <div class="highlight-card">
      <h3>Mock dataset</h3>
      <p>This demo uses mock entries that will later be replaced with the real screening database.</p>
    </div>
  </section>
</article>
