<article class="page-block">
  <header class="hero-block">
    <h2>{{ title }}</h2>
    {{ content }}
  </header>

  {% if site_stats.dataset_available %}
  {% if featured_materials.picked_interesting %}
  <section class="section-block">
    <div class="section-heading">
      <h3>Picked interesting altermagnets</h3>
    </div>
    <div class="highlight-grid">
      {% for item in featured_materials.picked_interesting %}
      <a class="highlight-card highlight-link" href="{{ page.relbaseurl }}/material?id={{ item.material_id }}">
        <h3>{{ item.material_label if item.material_label else item.material }}</h3>
        <p>{{ item.space_group }} | {{ item.classification_label }}</p>
        <p><strong>$\Delta E^{\mathrm{max}}_{\mathrm{split}}$:</strong> {{ item.max_ss_display }} eV</p>
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  <section class="section-block">
    <div class="section-heading">
      <h3>Largest spin splitting</h3>
      <p>These entries sit highest in the screening by reported maximum spin splitting.</p>
    </div>
    <div class="highlight-grid">
      {% for item in featured_materials.largest_splitting %}
      <a class="highlight-card highlight-link" href="{{ page.relbaseurl }}/material?id={{ item.material_id }}">
        <h3>{{ item.material_label if item.material_label else item.material }}</h3>
        <p>{{ item.space_group }} | {{ item.classification_label }}</p>
        <p><strong>$\Delta E^{\mathrm{max}}_{\mathrm{split}}$:</strong> {{ item.max_ss_display }} eV</p>
      </a>
      {% endfor %}
    </div>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <h3>Widest-gap candidates</h3>
      <p>Large-gap materials may be attractive where robust semiconducting behaviour matters alongside altermagnetic symmetry signatures.</p>
    </div>
    <div class="highlight-grid">
      {% for item in featured_materials.wide_gap %}
      <a class="highlight-card highlight-link" href="{{ page.relbaseurl }}/material?id={{ item.material_id }}">
        <h3>{{ item.material_label if item.material_label else item.material }}</h3>
        <p>{{ item.space_group }} | {{ item.classification_label }}</p>
        <p><strong>Band gap:</strong> {{ item.bandgap_display }} eV</p>
      </a>
      {% endfor %}
    </div>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <h3>Most earth-abundant constituents</h3>
      <p>Sorted by the minimum crustal abundance among constituent elements, to surface chemically accessible candidates.</p>
    </div>
    <div class="highlight-grid">
      {% for item in featured_materials.earth_abundant %}
      <a class="highlight-card highlight-link" href="{{ page.relbaseurl }}/material?id={{ item.material_id }}">
        <h3>{{ item.material_label if item.material_label else item.material }}</h3>
        <p>{{ item.space_group }} | {{ item.classification_label }}</p>
        <p><strong>Min abundance:</strong> {{ item.abundance_display }}</p>
      </a>
      {% endfor %}
    </div>
  </section>
  {% else %}
  <div class="notice-block">
    <p>{{ site_stats.notice }}</p>
  </div>
  {% endif %}
</article>
