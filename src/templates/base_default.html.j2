<!doctype html>
<html lang="en" data-theme="twilight">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title }} | Anyterial altermagnets</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=Instrument+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="{{ page.relbaseurl }}/styles.css" />
  </head>
  <body>
    <div class="app-shell">
      <header class="topbar panel">
        <div>
          <p class="kicker">Anyterial Screening Portal</p>
          <div class="brand-row">
            <img
              src="https://www.anyterial.se/img/anyterial_logo_color.svg"
              alt="Anyterial logo"
              class="brand-logo"
            />
            <h1>Anyterial altermagnets</h1>
          </div>
        </div>
        <div class="theme-switch" role="group" aria-label="Theme">
          <button class="theme-btn" type="button" data-theme-value="dark" title="Dark">Dark</button>
          <button class="theme-btn" type="button" data-theme-value="twilight" title="Twilight">Twilight</button>
          <button class="theme-btn" type="button" data-theme-value="light" title="Light">Light</button>
        </div>
      </header>

      <div class="layout-grid">
        <aside class="sidebar panel">
          <nav class="nav-links" aria-label="Primary">
            <a href="{{ page.relbaseurl }}/index" class="nav-link">Welcome</a>
            <a href="{{ page.relbaseurl }}/search" class="nav-link">Search</a>
          </nav>

          <section class="search-card">
            <h2>Search Materials</h2>
            <p>Filter by formula, element symbols, space group, or magnetic order.</p>
            <form method="get" action="{{ page.relbaseurl }}/search" class="search-form">
              <label for="global-search">Query</label>
              <input
                id="global-search"
                name="q"
                type="text"
                value="{{ query.q if query.q else '' }}"
                placeholder="e.g. Mn O, Fe, P4/nmm"
              />
              <button type="submit">Run search</button>
            </form>
          </section>
        </aside>

        <main class="content panel">
          {{ content }}
        </main>
      </div>
    </div>

    <script src="{{ page.relbaseurl }}/app.js"></script>
  </body>
</html>
